# Public client-side environment variables for the Supabase integration.
# Keep real values in `.env.local` locally and in Vercel Environment Variables remotely.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback if your project still uses anon keys instead of publishable keys.
VITE_SUPABASE_ANON_KEY=

# Server-side environment variable for AI Assist via the Vercel function.
OPENAI_API_KEY=
